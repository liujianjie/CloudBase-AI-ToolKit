# Copy to .env or .env.local and fill in. Not committed (see .gitignore).
# Used by layer integration tests when CLOUDBASE_RUN_LAYER_INTEGRATION_TESTS=1.

# CloudBase credentials (required for real integration tests)
# TENCENTCLOUD_SECRETID=
# TENCENTCLOUD_SECRETKEY=
# CLOUDBASE_ENV_ID=

# Optional: run layer real integration tests (create/attach/detach/delete)
# CLOUDBASE_RUN_LAYER_INTEGRATION_TESTS=1

# Optional: function name for attach/detach steps
# CLOUDBASE_LAYER_TEST_FUNCTION_NAME=
